{
  "name": "aws-ops-manager",
  "version": "2.0.2",
  "description": "多云 AKSK 运维管理桌面客户端",
  "main": "./out/main/index.js",
  "homepage": "https://github.com/S0x007/cloud-ops-manager",
  "repository": {
    "type": "git",
    "url": "https://github.com/S0x007/cloud-ops-manager.git"
  },
  "bugs": {
    "url": "https://github.com/S0x007/cloud-ops-manager/issues"
  },
  "author": "S0x007",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --noEmit",
    "package:mac": "npm run build && electron-builder --mac",
    "package:mac:arm64": "npm run build && electron-builder --mac --arm64",
    "package:win": "npm run build && electron-builder --win",
    "package:linux": "npm run build && electron-builder --linux",
    "package:all": "npm run build && electron-builder --mac --win --linux",
    "postinstall": "electron-builder install-app-deps"
  },
