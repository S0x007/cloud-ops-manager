    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/client-ssm": "^3.600.0",
    "@aws-sdk/client-sts": "^3.600.0",
    "@aws-sdk/credential-providers": "^3.600.0",
    "@aws-sdk/lib-storage": "^3.1053.0",
    "@aws-sdk/s3-request-presigner": "^3.1053.0",
