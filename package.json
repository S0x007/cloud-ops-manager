    "@huaweicloud/huaweicloud-sdk-vpc": "^3.1.197",
    "antd": "^5.22.0",
    "dayjs": "^1.11.13",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.9",
    "esdk-obs-nodejs": "^3.26.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
